<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <PublishSingleFile>true</PublishSingleFile>
        <SelfContained>true</SelfContained>
        <Nullable>enable</Nullable>
        <PublishReadyToRun>true</PublishReadyToRun>
    </PropertyGroup>

    <PropertyGroup>
        <DebugType>embedded</DebugType>
        <AssemblyName>PocketKnife</AssemblyName>
    </PropertyGroup>
    
    <ItemGroup>
      <PackageReference Include="CsvHelper" Version="33.1.0" />
      <PackageReference Include="Microsoft.PowerShell.Commands.Utility" Version="7.6.0" />
      <PackageReference Include="Microsoft.PowerShell.SDK" Version="7.6.0" />
      <PackageReference Include="System.Management.Automation" Version="7.6.0" />
    </ItemGroup>

</Project>
